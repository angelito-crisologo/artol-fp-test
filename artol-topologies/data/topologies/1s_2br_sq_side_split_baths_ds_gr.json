{
  "$schema": "https://aisolutionmaven.com/schemas/topology-v0.1.json",
  "id": "1s_2br_sq_side_split_baths_ds_gr",
  "label": "Squarish 2BR / 2 baths DISTRIBUTED with GREAT_ROOM \u2014 ensuite between master and standard in the private column; common T&B at rear-middle. Open-plan great_room + kitchen on the public side (gr style instead of separate L+D+K).",
  "target_shell": "squarish",
  "rooms": [
    {
      "id": "master",
      "type": "master_bedroom",
      "zone": "private",
      "size_priority": "master_bedroom"
    },
    {
      "id": "ensuite",
      "type": "ensuite_bath",
      "zone": "private",
      "size_priority": "service_and_baths"
    },
    {
      "id": "standard",
      "type": "bedroom_standard",
      "zone": "private",
      "size_priority": "other_bedrooms"
    },
    {
      "id": "common",
      "type": "common_bath",
      "zone": "service",
      "size_priority": "service_and_baths"
    },
    {
      "id": "great",
      "type": "great_room",
      "zone": "public",
      "size_priority": "public_LDK",
      "hosts_entry": true
    },
    {
      "id": "kitchen",
      "type": "kitchen",
      "zone": "public",
      "size_priority": "public_LDK"
    }
  ],
  "adjacencies": [
    {
      "a": "master",
      "b": "ensuite",
      "min_shared_wall_m": 0.8,
      "kind": "ensuite_door"
    },
    {
      "a": "ensuite",
      "b": "standard",
      "min_shared_wall_m": 0.8,
      "kind": "bath_to_bedroom_wall"
    },
    {
      "a": "standard",
      "b": "common",
      "min_shared_wall_m": 0.8,
      "kind": "bath_door"
    },
    {
      "a": "common",
      "b": "kitchen",
      "min_shared_wall_m": 1.0,
      "kind": "wet_core"
    },
    {
      "a": "common",
      "b": "great",
      "min_shared_wall_m": 0.7,
      "kind": "bath_door"
    },
    {
      "a": "master",
      "b": "great",
      "min_shared_wall_m": 1.0,
      "kind": "bedroom_to_public"
    },
    {
      "a": "standard",
      "b": "great",
      "min_shared_wall_m": 1.0,
      "kind": "bedroom_to_public"
    },
    {
      "a": "great",
      "b": "kitchen",
      "min_shared_wall_m": 1.5,
      "kind": "open_plan"
    }
  ],
  "soft_proximities": [
    {
      "a": "standard",
      "b": "common",
      "weight": 25
    }
  ],
  "entry_point": "great",
  "zone_split": {
    "axis": "vertical",
    "private_side": "left",
    "private_rooms": [
      "master",
      "ensuite",
      "standard"
    ],
    "public_rooms": [
      "great",
      "kitchen"
    ]
  },
  "match_bedroom_widths": true,
  "ensuite_alcove_joins_master": true,
  "left_anchored": [
    "master",
    "ensuite",
    "standard"
  ],
  "right_anchored": [
    "kitchen"
  ],
  "rear_anchored": [
    "standard",
    "common",
    "kitchen"
  ],
  "front_to_rear_stacks": [
    [
      "master",
      "ensuite",
      "standard"
    ],
    [
      "great",
      "kitchen"
    ]
  ],
  "lot_adjustment_profiles": [
    {
      "name": "compact_sq_side_split_baths_ds_gr",
      "when": {
        "buildable_area_lt_sqm": 100
      },
      "auto_apply": {
        "kitchen": {
          "min_least_dim_m": 1.5
        },
        "ensuite_bath": {
          "min_area_sqm": 2.5
        },
        "common_bath": {
          "min_area_sqm": 3.0
        },
        "master_bedroom": {
          "max_area_sqm": 18.0
        }
      },
      "preferred_apply": {
        "ensuite_bath": {
          "min_area_sqm": 3.0
        },
        "kitchen": {
          "min_least_dim_m": 2.0
        }
      },
      "rationale": "Same constraint shape as distributed_baths_ld. Auto floors bath area + caps master area. Preferred bumps ensuite to 3.0 and kitchen to 2.0 m where feasible."
    }
  ],
  "setback_elements": [
    {
      "type": "carport",
      "location": "side_setback",
      "covered": false,
      "width_m": 3.0,
      "depth_m": 6.0
    },
    {
      "type": "dirty_kitchen",
      "location": "rear_setback",
      "covered": false,
      "behind": "kitchen"
    },
    {
      "type": "service_area",
      "location": "rear_setback",
      "covered": false
    },
    {
      "type": "lanai",
      "location": "side_setback",
      "covered": false
    }
  ],
  "building_voids": [
    {
      "id": "carport_cut",
      "location": "front_right",
      "width_m": 1.0,
      "depth_m": 4.0,
      "consumed_by": "carport"
    }
  ],
  "notes": [
    "Sibling of distributed_baths_ld with one fewer LDK room \u2014 great_room replaces separate living + dining.",
    "Fewer rooms means smaller minimum-feasible carport lot (11-12 m sq instead of 12.5x13)."
  ]
}
