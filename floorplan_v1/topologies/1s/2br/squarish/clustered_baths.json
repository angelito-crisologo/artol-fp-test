{
  "$schema": "https://aisolutionmaven.com/schemas/topology-v0.1.json",
  "id": "squarish_two_bedroom_clustered_baths",
  "label": "Squarish 2BR — clustered baths (ensuite + common share a plumbing wall)",
  "target_shell": "squarish",

  "rooms": [
    { "id": "master",   "type": "master_bedroom",   "zone": "private", "size_priority": "master_bedroom" },
    { "id": "ensuite",  "type": "ensuite_bath",     "zone": "private", "size_priority": "service_and_baths" },
    { "id": "standard", "type": "bedroom_standard", "zone": "private", "size_priority": "other_bedrooms" },
    { "id": "common",   "type": "common_bath",      "zone": "service", "size_priority": "service_and_baths" },
    { "id": "great",    "type": "great_room",       "zone": "public",  "size_priority": "public_LDK", "hosts_entry": true },
    { "id": "kitchen",  "type": "kitchen",          "zone": "service", "size_priority": "public_LDK" }
  ],

  "adjacencies": [
    { "a": "master",   "b": "ensuite",  "min_shared_wall_m": 0.70, "kind": "ensuite_door" },
    { "a": "ensuite",  "b": "common",   "min_shared_wall_m": 1.20, "kind": "wet_core", "note": "shared plumbing wall between the two baths" },
    { "a": "common",   "b": "standard", "min_shared_wall_m": 0.80, "kind": "bath_to_bedroom_wall", "note": "common's south face touches standard — the bath block is the buffer between bedrooms" },
    { "a": "master",   "b": "great",    "min_shared_wall_m": 0.80, "kind": "bedroom_to_public" },
    { "a": "standard", "b": "great",    "min_shared_wall_m": 0.80, "kind": "bedroom_to_public" },
    { "a": "common",   "b": "great",    "min_shared_wall_m": 0.70, "kind": "bath_door", "note": "common is publicly accessible — door faces the great room" },
    { "a": "great",    "b": "kitchen",  "min_shared_wall_m": 1.50, "kind": "open_plan" }
  ],

  "soft_proximities": [
    { "a": "master", "b": "common", "weight": 20, "note": "secondary pull — keeps the master-side of the wet core hugging master rather than drifting" }
  ],

  "entry_point": "great",

  "match_bedroom_widths": true,

  "setback_elements": [
    { "type": "carport",       "location": "side_setback", "covered": false, "depth_m": 5.2 },
    { "type": "dirty_kitchen", "location": "rear_setback", "covered": false, "behind": "kitchen" },
    { "type": "service_area",  "location": "rear_setback", "covered": false, "behind": "left_zone" }
  ],

  "building_voids": [
    {
      "id": "carport_cut",
      "location": "front_right",
      "width_m": 1.0,
      "depth_m": 3.5,
      "consumed_by": "carport"
    }
  ],

  "front_to_rear_stacks": [
    ["master",  "common",   "standard"],
    ["master",  "ensuite",  "standard"],
    ["great",   "kitchen"]
  ],

  "notes": [
    "Clustered-baths variant where the wet core is the ensuite<->common plumbing wall,",
    "and the bath block sits BETWEEN the bedrooms (master on one side, standard on the other).",
    "The bath bar acts as the acoustic+privacy buffer separating sleeping spaces.",
    "Common remains publicly accessible via a door to dining.",
    "Differs from older variant that put common against the kitchen for the wet-core wall;",
    "that arrangement is dropped — plumbing for the kitchen is independent of the bath stack."
  ]
}
