{
  "$schema": "https://aisolutionmaven.com/schemas/topology-v0.1.json",
  "id": "wide_great_room_left_central_hall",
  "label": "Wide 2BR — great room on the left, central hall band, master+kitchen in middle column, standard+common bath in right column (single T&B)",
  "target_shell": "wide",

  "rooms": [
    { "id": "great",    "type": "great_room",       "zone": "public",      "size_priority": "public_LDK", "hosts_entry": true },
    { "id": "master",   "type": "master_bedroom",   "zone": "private",     "size_priority": "master_bedroom" },
    { "id": "standard", "type": "bedroom_standard", "zone": "private",     "size_priority": "other_bedrooms" },
    { "id": "hall",     "type": "hallway",          "zone": "circulation", "size_priority": "service_and_baths" },
    { "id": "kitchen",  "type": "kitchen",          "zone": "service",     "size_priority": "public_LDK" },
    { "id": "common",   "type": "common_bath",      "zone": "service",     "size_priority": "service_and_baths" },
    { "id": "wc",       "type": "bath_toilet",      "zone": "service",     "size_priority": "service_and_baths" }
  ],

  "adjacencies": [
    { "a": "master",   "b": "hall",    "min_shared_wall_m": 0.90, "kind": "bedroom_door", "note": "bedroom door: 0.8-0.9 m + frame, so 0.9 m shared wall (horizontal: hall sits above master)" },
    { "a": "standard", "b": "hall",    "min_shared_wall_m": 0.90, "kind": "bedroom_door", "note": "bedroom door: 0.8-0.9 m + frame, so 0.9 m shared wall (horizontal: hall sits above standard)" },
    { "a": "common",   "b": "hall",    "min_shared_wall_m": 0.85, "kind": "bath_door",    "note": "bathroom door: 700 mm clear + 75 mm frames = 850 mm shared wall (comfortable PH bath door, not just minimum spec)" },
    { "a": "great",    "b": "hall",    "min_shared_wall_m": 1.00, "kind": "main_door",    "note": "main door: 0.9-1.0 m + frame, so 1.0 m shared wall (vertical: great's east wall meets hall's west end)" },
    { "a": "great",    "b": "kitchen", "min_shared_wall_m": 1.50, "kind": "open_plan",    "note": "kitchen flows directly into the great room (vertical: great's east wall meets kitchen's west)" },
    { "a": "common",   "b": "kitchen", "min_shared_wall_m": 1.00, "kind": "wet_core",     "note": "common bath and kitchen share a plumbing wall at the rear — single wet stack" },
    { "a": "wc",       "b": "hall",    "min_shared_wall_m": 0.75, "kind": "bath_door",    "note": "bathroom door: 0.6-0.75 m + frame, so 0.75 m shared wall (vertical: wc sits east of hall, occupies the right-of-hall sliver between standard and common)" }
  ],

  "soft_proximities": [],

  "entry_point": "great",

  "rear_anchored": ["kitchen", "common"],

  "left_anchored": ["great"],

  "right_anchored": ["standard", "common", "wc"],

  "front_to_rear_stacks": [
    ["master",   "hall"],
    ["hall",     "kitchen"],
    ["standard", "wc"],
    ["wc",       "common"]
  ],

  "lot_adjustment_profiles": [
    {
      "name": "moderate wide (e.g., 16x10)",
      "when": { "buildable_depth_lt_m": 7.0 },
      "auto_apply": {
        "great_room":       { "min_area_sqm": 18.0 },
        "master_bedroom":   { "min_area_sqm": 12.0 },
        "bedroom_standard": { "min_area_sqm":  8.0 },
        "kitchen":          { "min_area_sqm":  6.0 },
        "common_bath":      { "min_area_sqm":  3.0 }
      }
    },
    {
      "name": "ample wide (e.g., 16x11+)",
      "when": { "buildable_depth_gte_m": 7.0 },
      "auto_apply": {
        "great_room":       { "min_area_sqm": 22.0 },
        "master_bedroom":   { "min_area_sqm": 14.0 },
        "bedroom_standard": { "min_area_sqm":  9.0 },
        "kitchen":          { "min_area_sqm":  6.5 },
        "common_bath":      { "min_area_sqm":  3.5 }
      }
    }
  ],

  "setback_elements": [
    { "type": "carport",       "location": "side_setback",  "covered": false },
    { "type": "dirty_kitchen", "location": "rear_setback",  "covered": false, "behind": "kitchen" },
    { "type": "service_area",  "location": "rear_setback",  "covered": false }
  ],

  "notes": [
    "Three-column wide 2BR with a single T&B and a horizontal hall band:",
    "",
    "  LEFT COLUMN (great room, full depth):",
    "    great room hosts the entry, runs front-to-rear, integrates living + dining",
    "",
    "  MIDDLE COLUMN (stacked front-to-rear):",
    "    master bedroom (front)",
    "    hall (middle)         <- the hall is ONE rectangle spanning the middle",
    "    kitchen (rear)            and right columns horizontally",
    "",
    "  RIGHT COLUMN (stacked front-to-rear):",
    "    standard bedroom (front)",
    "    hall (middle)         <- same hall continues across to the right column",
    "    common bath (rear)",
    "",
    "Access flows:",
    "  Front door -> great room (entry)",
    "  Great room -> hall (main door into the private/service spine)",
    "  Great room -> kitchen (open plan, kitchen is east of great)",
    "  Hall -> master (bedroom door, horizontal wall)",
    "  Hall -> standard (bedroom door, horizontal wall)",
    "  Hall -> common bath (bath door, horizontal wall above hall)",
    "  Common <-> kitchen (wet-core plumbing wall, vertical at rear)",
    "",
    "Lot intent: targets the wide shell. Lot profiles tune room min-areas for",
    "moderate (16x10, ~6 m buildable depth) vs. ample (16x11+, ~7 m depth) variants."
  ]
}
