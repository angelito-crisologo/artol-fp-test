{
  "$schema": "https://aisolutionmaven.com/schemas/topology-v0.1.json",
  "id": "squarish_two_bedroom_split_clustered_baths",
  "label": "Squarish 2BR — public/private split + private hallway + clustered baths (wet core)",
  "target_shell": "squarish",

  "rooms": [
    { "id": "master",   "type": "master_bedroom",   "zone": "private",     "size_priority": "master_bedroom" },
    { "id": "ensuite",  "type": "ensuite_bath",     "zone": "private",     "size_priority": "service_and_baths" },
    { "id": "standard", "type": "bedroom_standard", "zone": "private",     "size_priority": "other_bedrooms" },
    { "id": "common",   "type": "common_bath",      "zone": "service",     "size_priority": "service_and_baths" },
    { "id": "hall",     "type": "hallway",          "zone": "circulation", "size_priority": "service_and_baths" },
    { "id": "living",   "type": "living_room",      "zone": "public",      "size_priority": "public_LDK", "hosts_entry": true },
    { "id": "dining",   "type": "dining_room",      "zone": "public",      "size_priority": "public_LDK" },
    { "id": "kitchen",  "type": "kitchen",          "zone": "service",     "size_priority": "public_LDK" }
  ],

  "adjacencies": [
    { "a": "master",   "b": "ensuite", "min_shared_wall_m": 0.70, "kind": "ensuite_door" },
    { "a": "master",   "b": "hall",    "min_shared_wall_m": 0.80, "kind": "bedroom_to_hall" },
    { "a": "standard", "b": "hall",    "min_shared_wall_m": 0.80, "kind": "bedroom_to_hall" },
    { "a": "common",   "b": "hall",    "min_shared_wall_m": 0.70, "kind": "bath_door", "note": "common T&B opens off the hall, publicly reachable via hall->dining bridge" },
    { "a": "common",   "b": "kitchen", "min_shared_wall_m": 0.10, "kind": "wet_core",  "note": "shared plumbing wall with kitchen" },
    { "a": "hall",     "b": "dining",  "min_shared_wall_m": 0.90, "kind": "private_to_public", "note": "single hallway-mouth bridge across the dividing wall" },
    { "a": "living",   "b": "dining",  "min_shared_wall_m": 1.50, "kind": "open_plan" },
    { "a": "dining",   "b": "kitchen", "min_shared_wall_m": 1.50, "kind": "open_plan" }
  ],

  "soft_proximities": [
    { "a": "ensuite", "b": "common", "weight": 300, "note": "strong pull to cluster the two baths within the private wing" }
  ],

  "zone_split": {
    "axis": "vertical",
    "private_side": "left",
    "private_rooms": ["master", "ensuite", "standard", "common", "hall"],
    "public_rooms":  ["living", "dining", "kitchen"]
  },

  "entry_point": "living",

  "setback_elements": [
    { "type": "carport",       "location": "side_setback", "covered": false },
    { "type": "dirty_kitchen", "location": "rear_setback", "covered": false, "behind": "kitchen" },
    { "type": "service_area",  "location": "rear_setback", "covered": false, "behind": "left_zone" }
  ],

  "notes": [
    "Combines the public/private split with a private-wing hallway AND a clustered wet core.",
    "Hallway is the private-wing circulation node: both bedrooms and the common T&B open onto it.",
    "Common T&B remains publicly accessible — guests walk in via the hall-to-dining bridge.",
    "The strong ensuite<->common soft proximity pulls the two baths together against the kitchen wall, concentrating plumbing on a single wet core."
  ]
}
