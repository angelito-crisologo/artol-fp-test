{
  "$schema": "https://aisolutionmaven.com/schemas/topology-v0.1.json",
  "id": "squarish_two_bedroom_single_bath",
  "label": "Squarish 2BR + 1 T&B (single common bath off dining, wet-core with kitchen)",
  "target_shell": "squarish",

  "rooms": [
    { "id": "master",   "type": "master_bedroom",   "zone": "private", "size_priority": "master_bedroom" },
    { "id": "standard", "type": "bedroom_standard", "zone": "private", "size_priority": "other_bedrooms" },
    { "id": "common",   "type": "common_bath",      "zone": "service", "size_priority": "service_and_baths" },
    { "id": "living",   "type": "living_room",      "zone": "public",  "size_priority": "public_LDK", "hosts_entry": true },
    { "id": "dining",   "type": "dining_room",      "zone": "public",  "size_priority": "public_LDK" },
    { "id": "kitchen",  "type": "kitchen",          "zone": "service", "size_priority": "public_LDK" }
  ],

  "adjacencies": [
    { "a": "master",   "b": "dining",  "min_shared_wall_m": 0.80, "kind": "bedroom_to_public", "note": "master accessed off dining (no ensuite door means master uses the public bath)" },
    { "a": "standard", "b": "dining",  "min_shared_wall_m": 0.80, "kind": "bedroom_to_public", "note": "standard accessed off dining" },
    { "a": "common",   "b": "dining",  "min_shared_wall_m": 0.70, "kind": "bath_door",         "note": "single common bath off dining — guests + both bedrooms reach it from the LDK" },
    { "a": "common",   "b": "kitchen", "min_shared_wall_m": 0.50, "kind": "wet_core",          "note": "shared plumbing wall — kitchen + bath on a single wet stack" },
    { "a": "living",   "b": "dining",  "min_shared_wall_m": 1.50, "kind": "open_plan" },
    { "a": "dining",   "b": "kitchen", "min_shared_wall_m": 1.50, "kind": "open_plan" }
  ],

  "soft_proximities": [
    { "a": "common", "b": "standard", "weight": 20, "note": "common bath convenient to the second bedroom" }
  ],

  "entry_point": "living",

  "setback_elements": [
    { "type": "carport",       "location": "side_setback", "covered": false },
    { "type": "dirty_kitchen", "location": "rear_setback", "covered": false, "behind": "kitchen" },
    { "type": "service_area",  "location": "rear_setback", "covered": false }
  ],

  "notes": [
    "Compact 2BR + 1 T&B. No ensuite — both bedrooms share a single common",
    "bath accessed off the dining room. Bath shares its plumbing wall with the",
    "kitchen (the wet core).",
    "",
    "Use when the household opts out of a master ensuite to save space and",
    "cost: starter homes, smaller squarish lots, budget builds.",
    "",
    "Compared to squarish_two_bedroom_distributed_baths (1 ensuite + 1 common):",
    "one fewer bath frees floor area for the LDK to grow comfortably even on",
    "a smaller envelope, and plumbing is simpler (one wet stack vs two)."
  ]
}
