{
  "$schema": "https://aisolutionmaven.com/schemas/topology-v0.1.json",
  "id": "squarish_two_bedroom_v1",
  "label": "Squarish 2BR — bedrooms left stacked, common T&B rear-center, L-D-K right",
  "target_shell": "squarish",

  "rooms": [
    { "id": "master",   "type": "master_bedroom",   "zone": "private", "size_priority": "master_bedroom" },
    { "id": "ensuite",  "type": "ensuite_bath",     "zone": "private", "size_priority": "service_and_baths" },
    { "id": "standard", "type": "bedroom_standard", "zone": "private", "size_priority": "other_bedrooms" },
    { "id": "common",   "type": "common_bath",      "zone": "service", "size_priority": "service_and_baths" },
    { "id": "living",   "type": "living_room",      "zone": "public",  "size_priority": "public_LDK", "hosts_entry": true },
    { "id": "dining",   "type": "dining_room",      "zone": "public",  "size_priority": "public_LDK" },
    { "id": "kitchen",  "type": "kitchen",          "zone": "service", "size_priority": "public_LDK" }
  ],

  "adjacencies": [
    { "a": "master",   "b": "ensuite", "min_shared_wall_m": 0.70, "kind": "ensuite_door",      "note": "ensuite_bath opens ONLY to master_bedroom" },
    { "a": "master",   "b": "living",  "min_shared_wall_m": 0.80, "kind": "bedroom_to_public", "note": "master accessible from public space" },
    { "a": "standard", "b": "dining",  "min_shared_wall_m": 0.80, "kind": "bedroom_to_public", "note": "standard accessible from public space" },
    { "a": "common",   "b": "dining",  "min_shared_wall_m": 0.70, "kind": "bath_door",         "note": "common bath off the public area" },
    { "a": "common",   "b": "kitchen", "min_shared_wall_m": 0.10, "kind": "wet_core",          "note": "common bath shares wall with kitchen (plumbing core)" },
    { "a": "living",   "b": "dining",  "min_shared_wall_m": 1.50, "kind": "open_plan",         "note": "living flows into dining" },
    { "a": "dining",   "b": "kitchen", "min_shared_wall_m": 1.50, "kind": "open_plan",         "note": "dining flows into kitchen" }
  ],

  "soft_proximities": [
    { "a": "common", "b": "standard", "weight": 30, "note": "common T&B should be conveniently close to the standard bedroom" }
  ],

  "entry_point": "living",

  "setback_elements": [
    { "type": "carport",       "location": "side_setback", "covered": false },
    { "type": "dirty_kitchen", "location": "rear_setback", "covered": false, "behind": "kitchen" },
    { "type": "service_area",  "location": "rear_setback", "covered": false, "behind": "left_zone" }
  ],

  "notes": [
    "Hand-authored equivalent of the Phase A squarish_two_bedroom template.",
    "Used as the C.1 benchmark: solving this topology on the same lot should produce a layout comparable to (and ideally as good as) the template version.",
    "Composite (L-shaped) rooms are not used in C.1 v0; all rooms are single rectangles."
  ]
}
