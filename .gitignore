floorplan_v1/test_output/

# Manual min/med/max lot-size sweep scratch (re-rendered each sweep_test.py
# run; the briefs/test_sweep/ fixtures themselves ARE committed)
floorplan_v1/sweep_output/

# LLM topology cache — brief-hash keyed, machine-local, not portable
floorplan_v1/cache/

# Local env / secrets
.env
.env.local
.anthropic_key
.anthropic_key.txt
.streamlit/secrets.toml

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Python virtual environment (local, machine-specific)
.venv/

# Claude Code local settings / agent-skill symlinks (machine-local, point
